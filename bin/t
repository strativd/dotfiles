#!/bin/sh
#
# Quick shortcut to a terminal.
#
# This means that as I travel back and forth between terminal apps, hey, I don't
# have to re-learn any arcane commands. Neat.
#
# USAGE:
#
#   $ t
#   # => opens the current directory in your terminal
#
#   $ t .
#   $ t /usr/local
#   # => opens the specified directory in your terminal
path="$(cd "${1:-.}" && pwd)" || exit 1

exec open -a "$TERMINAL" "$path"
