#!/usr/bin/env zsh
# git-cow: invoked as `git cow` — prints selected worktree path to stdout.
# Change directory in your shell: cd "$(git cow)"
# Or use the zsh function git-cow for a one-step cd.

_bin="${0:A:h}"
_dotfiles="${_bin:h}"
if [[ ! -r "$_dotfiles/git/worktree.zsh" ]]; then
  print -u2 "git-cow: missing $_dotfiles/git/worktree.zsh"
  exit 1
fi

source "$_dotfiles/git/worktree.zsh"
git_checkout_worktree
exit $?
