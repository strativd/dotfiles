{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-opencode@3.11.1"
  ],
  "model": "moonshotai/kimi-k2.5",
  "small_model": "opencode/gpt-5-nano",
  "autoupdate": true,
  "compaction": {
    "auto": true,
    "prune": true
  },
  "tools": {
    "read": true,
    "edit": true,
    "write": true,
    "bash": true
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**",
      "**/*.log"
    ]
  },
  "permission": {
    "read": {
      "~/.config/opencode/get-shit-done/*": "allow"
    },
    "external_directory": {
      "~/.config/opencode/get-shit-done/*": "allow"
    }
  }
}
