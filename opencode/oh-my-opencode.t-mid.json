{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "__ROLE__": "Primary orchestrator",
      "model": "opencode/claude-sonnet-4-6"
    },
    "hephaestus": {
      "__ROLE__": "Autonomous deep worker, The Legitimate Craftsman",
      "model": "opencode/gpt-5.4"
    },
    "oracle": {
      "__ROLE__": "Consultation, debugging",
      "model": "opencode/claude-sonnet-4-6",
      "variant": "high"
    },
    "librarian": {
      "__ROLE__": "Docs, GitHub search",
      "model": "opencode/gpt-5.3-codex-spark"
    },
    "explore": {
      "__ROLE__": "Fast contextual grep",
      "model": "opencode/gpt-5.3-codex-spark"
    },
    "multimodal-looker": {
      "__ROLE__": "PDF/image analysis",
      "model": "opencode/gemini-3.1-pro"
    },
    "prometheus": {
      "__ROLE__": "Strategic planning",
      "model": "opencode/kimi-k2.6",
      "variant": "max"
    },
    "metis": {
      "__ROLE__": "Pre-planning analysis",
      "model": "opencode/claude-sonnet-4-6",
      "variant": "high"
    },
    "momus": {
      "__ROLE__": "Plan validation",
      "model": "opencode/gpt-5.3-codex",
      "variant": "high"
    },
    "atlas": {
      "__ROLE__": "Master orchestrator",
      "model": "opencode/claude-sonnet-4-6"
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "opencode/gemini-3.1-pro"
    },
    "ultrabrain": {
      "model": "opencode/gpt-5.4",
      "variant": "high"
    },
    "artistry": {
      "model": "opencode/gemini-3.1-pro",
      "variant": "high"
    },
    "quick": {
      "model": "opencode/gemini-3-flash"
    },
    "unspecified-low": {
      "model": "opencode/gpt-5.3-codex-spark"
    },
    "unspecified-high": {
      "model": "opencode/claude-opus-4-6"
    },
    "writing": {
      "model": "opencode/gemini-3-flash"
    }
  }
}
